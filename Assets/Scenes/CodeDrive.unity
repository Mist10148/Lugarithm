  m_Color: {r: 1, g: 1, b: 1, a: 1}
  m_RaycastTarget: 0
  m_RaycastPadding: {x: 0, y: 0, z: 0, w: 0}
  m_Maskable: 1
  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "Drive the jeepney by programming it. Build a program (blocks or code \u2014
    set in\nSettings), then press \u25B6 RUN. One action runs per tick.\n\n<b>ACTIONS</b> 
    (do something; one tick each)\n  moveForward()   move one tile in the way you're
    facing (bumps on a wall)\n  turnLeft()      rotate 90\xB0 left      turnRight() 
    rotate 90\xB0 right\n  pickUp()        board the passenger on this stop\n  dropOff()      
    let passengers off at the destination\n  collectFare()   collect fare from everyone
    aboard\n\n<b>CONDITIONS</b>  (ask a yes/no question; used by if / while)\n  frontIsClear()  
    leftIsClear()   rightIsClear()\n  atStop()         atDestination()\n\n<b>CONTROL
    FLOW</b>\n  if CONDITION:           run the indented block once if true\n  if
    CONDITION: else:     ... otherwise run the else block\n  while CONDITION:       
    repeat the block while true\n  not CONDITION           flip a condition (e.g.
    while not atDestination():)\n\nIn the Code Editor end if/else/while with a colon
    ':' and indent the body 4\nspaces; '#' starts a comment. In Blocks, drop blocks
    inside the C-shaped\nif/while and click the condition chip to choose the question.\n\n<b>EXAMPLE</b>
    \u2014 follow the road to the destination:\n  while not atDestination():\n     
    if frontIsClear():\n          moveForward()\n      else:\n          turnLeft()"
  m_isRightToLeft: 0
